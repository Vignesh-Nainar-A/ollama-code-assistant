# Ollama Code Assistant - Configuration

## Model Selection
# Change this to use any Ollama model installed on your system
# 
# Recommended models:
# - llama3        (default) - Best overall balance for coding
# - codellama     - Specialized for code generation
# - mistral       - Fast and efficient
# - neural-chat   - Optimized for conversations
# - llama2        - Previous generation
# - orca-mini     - Small and lightweight
# - phi           - Very lightweight for low-end machines
#
# To use a different model:
# 1. Make sure the model is pulled: ollama pull <model-name>
# 2. Set OLLAMA_MODEL environment variable: export OLLAMA_MODEL=mistral
# 3. Or change ollamaModel in this file and recompile: npm run compile
#
# Example: To use Mistral, run this before starting:
# Windows (PowerShell):
#   $env:OLLAMA_MODEL = "mistral"
#
# Windows (Command Prompt):
#   set OLLAMA_MODEL=mistral
#
# Mac/Linux:
#   export OLLAMA_MODEL=mistral

OLLAMA_MODEL=llama3

## Ollama Server Configuration
# The address where Ollama is running
# Default: http://localhost:11434
# Change this if you're running Ollama on a different machine

OLLAMA_API_URL=http://localhost:11434
